---
layout: base.njk
title: "Contact — Cabir Çelik"
nav: contact
permalink: /contact/
---
<div class="page-contact">
  <h1 class="page-header__title">{{ contact.heading }}</h1>

  {% if contact.body %}
  <p class="contact-body">{{ contact.body }}</p>
  {% endif %}

  <ul class="profile-links profile-links--large" aria-label="Profiles">
    {% for profile in contact.profiles %}
    <li><a href="{{ profile.url }}">{{ profile.label }}</a></li>
    {% endfor %}
  </ul>

  <dl class="contact-meta">
    <div class="contact-meta__row">
      <dt class="mono">Location</dt>
      <dd>{{ contact.location }}</dd>
    </div>
    {% if contact.languages %}
    <div class="contact-meta__row">
      <dt class="mono">Languages</dt>
      <dd>
        <ul class="language-list">
          {% for lang in contact.languages %}
          <li>{{ lang }}</li>
          {% endfor %}
        </ul>
      </dd>
    </div>
    {% endif %}
  </dl>
</div>
