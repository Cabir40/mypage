---
layout: base.njk
title: "Projects — Cabir Çelik"
nav: projects
permalink: /projects/
---
<div class="page-projects">
  <header class="page-header">
    <h1 class="page-header__title">Projects</h1>
    <p class="page-header__subtitle mono">{{ projects | length }} projects</p>
  </header>

  <ul class="project-grid">
    {% for project in projects %}
    <li class="project-card">
      <div class="project-card__body">
        <h2 class="project-card__title">{{ project.title }}</h2>
        <p class="project-card__stack mono">{{ project.stack }}</p>
        {% if project.description %}
        <p class="project-card__description">{{ project.description }}</p>
        {% endif %}
      </div>
      <footer class="project-card__links">
        {% if project.demo %}
        <a href="{{ ('/demos/' + project.demo + '/') | url }}">Demo write-up &rarr;</a>
        {% endif %}
        {% if project.link %}
        <a href="{{ project.link }}">Source &rarr;</a>
        {% endif %}
      </footer>
    </li>
    {% endfor %}
  </ul>
</div>
