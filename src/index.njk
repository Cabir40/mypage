---
layout: base.njk
title: "Cabir Çelik — Lead Data Scientist"
nav: home
permalink: /
---
<div class="page-home">
  <aside class="home-sidebar" aria-label="On this page">
    <p class="home-sidebar__heading mono">On this page</p>
    <nav>
      <a class="home-sidebar__link" href="#about">About</a>
      <a class="home-sidebar__link" href="#experience">Experience</a>
      <a class="home-sidebar__link" href="#education">Education</a>
      <a class="home-sidebar__link" href="#publications">Publications</a>
    </nav>
  </aside>
  <div class="home-main">

  <section class="hero" id="about" aria-label="Introduction">
    <div class="hero__grid">
      <img class="hero__avatar" src="{{ '/assets/avatar.jpg' | url }}" alt="Portrait of {{ home.about.name }}" width="96" height="96">
      <div class="hero__text">
        <h1 class="hero__name">{{ home.about.name }}</h1>
        <p class="hero__title">{{ home.about.title }}</p>
        <p class="hero__location mono">{{ home.about.location }}</p>
        <ul class="badge-list" aria-label="Specialisms">
          {% for badge in home.about.badges %}
          <li class="badge">{{ badge }}</li>
          {% endfor %}
        </ul>
        <ul class="profile-links" aria-label="Profiles">
          {% for profile in home.about.profiles %}
          <li><a href="{{ profile.url }}">{{ profile.label }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>
    {% if home.about.content %}
    <div class="prose hero__bio">{{ home.about.content | safe }}</div>
    {% endif %}
  </section>

  <section class="content-section" id="experience" aria-labelledby="experience-heading">
    <h2 id="experience-heading" class="section-heading">Experience</h2>
    <ol class="timeline" reversed>
      {% for job in home.experience %}
      <li class="timeline-item">
        <p class="timeline-item__dates mono">{{ job.dates }}</p>
        <h3 class="timeline-item__role">{{ job.role }}</h3>
        <p class="timeline-item__org">{{ job.org }}{% if job.location %} &middot; {{ job.location }}{% endif %}</p>
        {% if job.bullets %}
        <ul class="timeline-item__bullets">
          {% for bullet in job.bullets %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </li>
      {% endfor %}
    </ol>
  </section>

  <section class="content-section" id="education" aria-labelledby="education-heading">
    <h2 id="education-heading" class="section-heading">Education</h2>
    <ol class="timeline" reversed>
      {% for degree in home.education %}
      <li class="timeline-item">
        <p class="timeline-item__dates mono">{{ degree.dates }}</p>
        <h3 class="timeline-item__role">{{ degree.degree }}</h3>
        <p class="timeline-item__org">{{ degree.institution }}{% if degree.location %} &middot; {{ degree.location }}{% endif %}</p>
        {% if degree.thesis %}
        <blockquote class="thesis-quote">
          <p class="thesis-quote__title">{{ degree.thesis.title }}</p>
          {% if degree.thesis.citation %}
          <p class="thesis-quote__citation mono">{{ degree.thesis.citation }}</p>
          {% endif %}
        </blockquote>
        {% endif %}
        {% if degree.body %}
        <p class="timeline-item__body">{{ degree.body }}</p>
        {% endif %}
      </li>
      {% endfor %}
    </ol>
  </section>

  <section class="content-section" id="publications" aria-labelledby="publications-heading">
    <h2 id="publications-heading" class="section-heading">Publications</h2>
    <ol class="pub-list">
      {% for pub in home.publications %}
      <li class="pub-item">
        <span class="pub-item__tag mono">{{ pub.tag }}</span>
        <h3 class="pub-item__title">
          {% if pub.link %}<a href="{{ pub.link }}">{{ pub.title }}</a>{% else %}{{ pub.title }}{% endif %}
        </h3>
        <p class="pub-item__venue mono">{{ pub.venue }}</p>
        {% if pub.tldr %}<p class="pub-item__tldr">{{ pub.tldr }}</p>{% endif %}
        {% if pub.citation %}<p class="pub-item__citation mono">{{ pub.citation }}</p>{% endif %}
      </li>
      {% endfor %}
    </ol>
  </section>

  </div>{# end .home-main #}
</div>{# end .page-home #}
