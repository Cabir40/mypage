---
layout: base.njk
title: "Demos — Cabir Çelik"
nav: demos
permalink: /demos/
---
<div class="page-demos">
  <header class="page-header">
    <h1 class="page-header__title">Demos</h1>
    <p class="page-header__subtitle mono">Project write-ups and deep-dives</p>
  </header>

  {% if demos | length %}
  <ul class="demo-list">
    {% for demo in demos %}
    <li class="demo-card">
      <div class="demo-card__meta">
        {% if demo.volume %}<span class="demo-card__vol mono">{{ demo.volume }}</span>{% endif %}
        {% if demo.issue %}<span class="demo-card__issue mono">{{ demo.issue }}</span>{% endif %}
      </div>
      <h2 class="demo-card__title">
        <a href="{{ ('/demos/' + demo.slug + '/') | url }}">{{ demo.title }}</a>
      </h2>
      {% if demo.subtitle %}<p class="demo-card__subtitle">{{ demo.subtitle }}</p>{% endif %}
      {% if demo.pullquote %}<blockquote class="demo-card__pullquote">{{ demo.pullquote }}</blockquote>{% endif %}
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p class="empty-state">No demos yet — check back soon.</p>
  {% endif %}
</div>
